{
  "experiment_name": "phase5_llama32_1b_ordering_study_4bit",
  "description": "Ordering-effect study on Meta Llama 3.2 1B Instruct using one shared list-based prompt, five fixed orderings, two temperatures, and 4-bit loading.",
  "seed": 20260328,
  "repetitions_per_condition": 80,
  "digits": [1, 2, 3, 4, 5, 6, 7, 8, 9],
  "prompt_template_file": "prompts/phase2_qwen_smoke_templates.json",
  "prompt_ids": ["phase2_qwen_list_answer"],
  "ordering_modes": ["ascending", "descending", "random"],
  "random_orderings_per_prompt": 3,
  "temperatures": [0.0, 0.2],
  "top_p": 1.0,
  "max_output_tokens": 2,
  "continue_on_error": false,
  "analysis": {
    "enabled": true,
    "output_dir": "results/processed"
  },
  "client": {
    "provider": "transformers",
    "model_name": "meta-llama/Llama-3.2-1B-Instruct",
    "params": {
      "device": "cuda",
      "device_map": "auto",
      "torch_dtype": "float16",
      "load_in_4bit": true,
      "bnb_4bit_compute_dtype": "float16",
      "bnb_4bit_quant_type": "nf4",
      "bnb_4bit_use_double_quant": true,
      "apply_chat_template": true,
      "chat_role": "user",
      "candidate_surface_prefixes": ["", " ", "\n"],
      "neutralize_generation_defaults": true
    }
  },
  "logprob": {
    "enabled": true,
    "top_k": 20
  }
}
