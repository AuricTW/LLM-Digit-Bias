{
  "experiment_name": "baseline_mock_uniform",
  "description": "Phase 1 baseline run using the built-in mock client to validate the full pipeline.",
  "seed": 20260328,
  "repetitions_per_condition": 40,
  "digits": [1, 2, 3, 4, 5, 6, 7, 8, 9],
  "prompt_template_file": "prompts/default_templates.json",
  "prompt_ids": [
    "template_1_baseline",
    "template_2_fair_csv",
    "template_3_choice_list",
    "template_4_uniform_range"
  ],
  "ordering_modes": ["ascending", "descending", "random"],
  "random_orderings_per_prompt": 2,
  "temperatures": [0.0, 0.2, 0.7, 1.0],
  "top_p": 1.0,
  "max_output_tokens": 4,
  "continue_on_error": false,
  "analysis": {
    "enabled": true,
    "output_dir": "results/processed"
  },
  "client": {
    "provider": "mock",
    "model_name": "mock-uniform",
    "params": {
      "mode": "uniform"
    }
  },
  "logprob": {
    "enabled": false,
    "top_k": 20
  }
}
