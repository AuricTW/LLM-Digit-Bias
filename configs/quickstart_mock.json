  "max_output_tokens": 4,
  "continue_on_error": false,
  "analysis": {
    "enabled": true,
    "output_dir": "results/processed"
  },
  "client": {
    "provider": "mock",
    "model_name": "mock-uniform",
    "params": {
      "mode": "uniform"
    }
  },
  "logprob": {
    "enabled": false,
    "top_k": 20
  }
}
