{
  "experiment_name": "quickstart_mock_uniform",
  "description": "Fast smoke test for the experiment pipeline.",
  "seed": 20260328,
  "repetitions_per_condition": 10,
  "digits": [1, 2, 3, 4, 5, 6, 7, 8, 9],
  "prompt_template_file": "prompts/default_templates.json",
  "prompt_ids": ["template_1_baseline", "template_2_fair_csv"],
  "ordering_modes": ["ascending", "descending", "random"],
  "random_orderings_per_prompt": 1,
